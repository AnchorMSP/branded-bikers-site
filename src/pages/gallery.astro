---
import Layout from '../layouts/Layout.astro';

const photos = [
  { src: '/images/harley-urban.jpg',         label: 'Street Run',           location: 'Urban',              tag: 'Rally'     },
  { src: '/images/rider-corner.jpg',          label: 'Corner Work',          location: 'Open Road',          tag: 'Rally'     },
  { src: '/images/aerial-mountain-rider.jpg', label: 'Mountain Pass',        location: 'Colorado Rockies',   tag: 'Rally'     },
  { src: '/images/desert-highway.jpg',        label: 'Desert Run',           location: 'Eastern Sierra, CA', tag: 'Road Trip' },
  { src: '/images/mountain-highway.jpg',      label: 'Open Horizon',         location: 'Southwest',          tag: 'Road Trip' },
  { src: '/images/open-road-mountains.jpg',   label: 'Endless Road',         location: 'Route 66',           tag: 'Road Trip' },
  { src: '/images/mountain-road-romania.webp',label: 'Transfăgărășan Pass',  location: 'Romania',            tag: 'Road Trip' },
  { src: '/images/autumn-road.jpg',           label: 'Fall Colors',          location: 'Appalachian Trail',  tag: 'Road Trip' },
  { src: '/images/rider-mountain-night.jpg',  label: 'Night Rider',          location: 'Mountain Road',      tag: 'Community' },
  { src: '/images/pov-coastal-road.jpg',      label: 'Rider POV',            location: 'Coastal Highway',    tag: 'Community' },
  { src: '/images/utah-canyon-road.jpg',       label: 'Red Rock Run',         location: 'Moab, UT',           tag: 'Road Trip' },
  { src: '/images/himalayan-solo-rider.jpg',  label: 'High Altitude Pass',   location: 'Himalayas, India',   tag: 'Road Trip' },
  { src: '/images/ktm-forest-road.jpg',       label: 'KTM in the Wild',      location: 'Forest Road',        tag: 'Show'      },
  { src: '/images/desert-scrambler.jpg',      label: 'Desert Scrambler',     location: 'Mojave Desert, CA',  tag: 'Show'      },
  { src: '/images/himalayan-group-ride.jpg',  label: 'Group Ride',           location: 'Leh-Ladakh, India',  tag: 'Road Trip' },
];
---

<Layout title="Gallery" description="See BrandedBikers in action — real riders, real events, real brand exposure across America.">

  <div class="page-hero">
    <div class="container">
      <span class="section-label">In the Wild</span>
      <h1 class="section-title">SEE IT IN <span>ACTION</span></h1>
      <p>Real riders. Real events. Real impact — from Sturgis to your backyard.</p>
    </div>
  </div>

  <!-- ── Filter bar ─────────────────────────── -->
  <div class="filter-bar">
    <div class="container filter-inner">
      <span class="filter-label">Filter:</span>
      <div class="filters">
        {['All', 'Rally', 'Road Trip', 'Community', 'Show'].map(f => (
          <button class:list={['filter-btn', { active: f === 'All' }]} data-filter={f}>{f}</button>
        ))}
      </div>
      <span class="photo-count" id="photo-count">{photos.length} photos</span>
    </div>
  </div>

  <!-- ── Gallery grid ───────────────────────── -->
  <section class="section gallery-section">
    <div class="container">
      <div class="gallery-grid" id="gallery-grid">
        {photos.map(p => (
          <div class="gallery-item" data-tag={p.tag}>
            <div class="gallery-img">
              <img
                src={p.src}
                alt={p.label}
                loading="lazy"
                decoding="async"
              />
              <div class="gallery-overlay">
                <span class="overlay-tag">{p.tag}</span>
              </div>
            </div>
            <div class="gallery-caption">
              <span class="caption-title">{p.label}</span>
              <span class="caption-loc"><i class="ti ti-map-pin"></i>{p.location}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Submit CTA ─────────────────────────── -->
  <section class="submit-section">
    <div class="container submit-inner">
      <div class="submit-text">
        <h3 class="submit-title">ARE YOU A RIDER WITH PHOTOS TO SHARE?</h3>
        <p>If you're in the BrandedBikers network and want to see your ride featured here, reach out directly.</p>
      </div>
      <a href="/contact" class="btn btn-primary">Submit Your Photos</a>
    </div>
  </section>

</Layout>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items = document.querySelectorAll<HTMLElement>('.gallery-item');
  const countEl = document.getElementById('photo-count');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const filter = btn.dataset.filter ?? 'All';
      let visible = 0;
      items.forEach(item => {
        const show = filter === 'All' || item.dataset.tag === filter;
        item.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (countEl) countEl.textContent = `${visible} photo${visible !== 1 ? 's' : ''}`;
    });
  });
</script>

<style>
  .filter-bar {
    background: var(--bg-card);
    border-bottom: 1px solid var(--border);
    padding: 1rem 0;
  }

  .filter-inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .filter-label {
    font-size: 11px;
    letter-spacing: 2px;
    color: var(--text-muted);
    text-transform: uppercase;
    font-family: var(--font-display);
  }

  .filters { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  .filter-btn {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-family: var(--font-display);
    font-size: 12px;
    letter-spacing: 1.5px;
    padding: 0.35rem 0.9rem;
    cursor: pointer;
    transition: all 0.15s;
  }

  .filter-btn:hover,
  .filter-btn.active {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--white);
  }

  .photo-count {
    margin-left: auto;
    font-size: 11px;
    letter-spacing: 1px;
    color: var(--text-muted);
    font-family: var(--font-display);
  }

  .gallery-section { padding-top: 3rem; }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }

  .gallery-item { display: flex; flex-direction: column; }

  .gallery-img {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: var(--bg-card);
  }

  .gallery-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .gallery-item:hover .gallery-img img { transform: scale(1.04); }

  .gallery-overlay {
    position: absolute;
    top: 10px;
    right: 10px;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .gallery-item:hover .gallery-overlay { opacity: 1; }

  .overlay-tag {
    background: var(--accent);
    color: var(--white);
    font-family: var(--font-display);
    font-size: 11px;
    letter-spacing: 1.5px;
    padding: 3px 8px;
  }

  .gallery-caption {
    background: var(--bg-card);
    padding: 0.75rem 0.9rem;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .caption-title {
    font-family: var(--font-display);
    font-size: 14px;
    color: var(--text);
    letter-spacing: 0.3px;
  }

  .caption-loc {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 11.5px;
    color: var(--text-muted);
  }

  .caption-loc i { font-size: 12px; color: var(--accent); }

  .submit-section {
    background: var(--bg-dark);
    border-top: 1px solid var(--border);
    padding: 3rem 0;
  }

  .submit-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .submit-text { max-width: 560px; }

  .submit-title {
    font-family: var(--font-display);
    font-size: 22px;
    color: var(--white);
    letter-spacing: 0.5px;
    margin-bottom: 0.5rem;
  }

  .submit-text p { font-size: 13.5px; color: var(--text-muted); line-height: 1.65; }

  @media (max-width: 768px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
    .submit-inner { flex-direction: column; }
    .photo-count { margin-left: 0; }
  }

  @media (max-width: 480px) {
    .gallery-grid { grid-template-columns: 1fr; }
  }
</style>
