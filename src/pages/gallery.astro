---
import Layout from '../layouts/Layout.astro';

const events = [
  { label: 'Sturgis Motorcycle Rally', location: 'Sturgis, SD', tag: 'Rally' },
  { label: 'Daytona Bike Week', location: 'Daytona Beach, FL', tag: 'Rally' },
  { label: 'Route 66 Run', location: 'Chicago → LA', tag: 'Road Trip' },
  { label: 'Laconia Motorcycle Week', location: 'Laconia, NH', tag: 'Rally' },
  { label: 'Local Bike Night', location: 'Various', tag: 'Community' },
  { label: 'Mountain Pass Ride', location: 'Rocky Mountains', tag: 'Road Trip' },
  { label: 'Bikes on the Boardwalk', location: 'Ocean City, MD', tag: 'Show' },
  { label: 'Thunder in the Valley', location: 'Johnstown, PA', tag: 'Rally' },
  { label: 'Arizona Desert Run', location: 'Phoenix, AZ', tag: 'Road Trip' },
];
---

<Layout title="Gallery" description="See BrandedBikers in action — real riders, real events, real brand exposure across America.">

  <div class="page-hero">
    <div class="container">
      <span class="section-label">In the Wild</span>
      <h1 class="section-title">SEE IT IN <span>ACTION</span></h1>
      <p>Real riders. Real events. Real impact — from Sturgis to your backyard.</p>
    </div>
  </div>

  <!-- ── Filter bar ─────────────────────────── -->
  <div class="filter-bar">
    <div class="container filter-inner">
      <span class="filter-label">Filter by type:</span>
      <div class="filters" id="filters">
        {['All', 'Rally', 'Road Trip', 'Community', 'Show'].map(f => (
          <button class:list={['filter-btn', { active: f === 'All' }]} data-filter={f}>{f}</button>
        ))}
      </div>
    </div>
  </div>

  <!-- ── Gallery grid ───────────────────────── -->
  <section class="section gallery-section">
    <div class="container">
      <div class="gallery-grid" id="gallery-grid">
        {events.map((e, i) => (
          <div class="gallery-item" data-tag={e.tag}>
            <div class="gallery-img">
              <div class="img-placeholder">
                <i class="ti ti-camera"></i>
              </div>
              <div class="gallery-overlay">
                <span class="overlay-tag">{e.tag}</span>
              </div>
            </div>
            <div class="gallery-caption">
              <span class="caption-title">{e.label}</span>
              <span class="caption-loc"><i class="ti ti-map-pin"></i>{e.location}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Submit CTA ─────────────────────────── -->
  <section class="submit-section">
    <div class="container submit-inner">
      <div class="submit-text">
        <h3 class="submit-title">ARE YOU A RIDER WITH PHOTOS TO SHARE?</h3>
        <p>If you're in the BrandedBikers network and want to see your ride featured here, submit your photos through the rider portal or reach out directly.</p>
      </div>
      <a href="/contact" class="btn btn-primary">Submit Your Photos</a>
    </div>
  </section>

</Layout>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items = document.querySelectorAll<HTMLElement>('.gallery-item');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const filter = btn.dataset.filter ?? 'All';
      items.forEach(item => {
        const show = filter === 'All' || item.dataset.tag === filter;
        item.style.display = show ? '' : 'none';
      });
    });
  });
</script>

<style>
  /* Filter bar */
  .filter-bar {
    background: var(--bg-card);
    border-bottom: 1px solid var(--border);
    padding: 1rem 0;
  }

  .filter-inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .filter-label {
    font-size: 11px;
    letter-spacing: 2px;
    color: var(--text-muted);
    text-transform: uppercase;
    font-family: var(--font-display);
  }

  .filters { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  .filter-btn {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-family: var(--font-display);
    font-size: 12px;
    letter-spacing: 1.5px;
    padding: 0.35rem 0.9rem;
    cursor: pointer;
    transition: all 0.15s;
  }

  .filter-btn:hover,
  .filter-btn.active {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--white);
  }

  /* Gallery */
  .gallery-section { padding-top: 3rem; }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .gallery-item { display: flex; flex-direction: column; }

  .gallery-img {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: var(--bg-card);
  }

  .img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 36px;
    color: var(--border);
    transition: color 0.2s;
  }

  .gallery-item:hover .img-placeholder { color: var(--accent); }

  .gallery-overlay {
    position: absolute;
    top: 10px;
    right: 10px;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .gallery-item:hover .gallery-overlay { opacity: 1; }

  .overlay-tag {
    background: var(--accent);
    color: var(--white);
    font-family: var(--font-display);
    font-size: 11px;
    letter-spacing: 1.5px;
    padding: 3px 8px;
  }

  .gallery-caption {
    background: var(--bg-card);
    padding: 0.75rem 0.9rem;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .caption-title {
    font-family: var(--font-display);
    font-size: 14px;
    color: var(--text);
    letter-spacing: 0.3px;
  }

  .caption-loc {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 11.5px;
    color: var(--text-muted);
  }

  .caption-loc i { font-size: 12px; color: var(--accent); }

  /* Submit section */
  .submit-section {
    background: var(--bg-dark);
    border-top: 1px solid var(--border);
    padding: 3rem 0;
  }

  .submit-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .submit-text { max-width: 560px; }

  .submit-title {
    font-family: var(--font-display);
    font-size: 22px;
    color: var(--white);
    letter-spacing: 0.5px;
    margin-bottom: 0.5rem;
  }

  .submit-text p { font-size: 13.5px; color: var(--text-muted); line-height: 1.65; }

  @media (max-width: 768px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
    .submit-inner { flex-direction: column; }
  }

  @media (max-width: 480px) {
    .gallery-grid { grid-template-columns: 1fr; }
  }
</style>
