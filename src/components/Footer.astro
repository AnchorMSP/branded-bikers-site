---
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-col">
      <div class="footer-brand">
        <img src="/BBNoBG.png" alt="BrandedBikers" width="36" height="36" />
        <span>BRANDEDBIKERS</span>
      </div>
      <p class="footer-desc">Authentic biker marketing putting your brand on rider backs across America.</p>
      <p class="footer-status"><span class="status-dot"></span> Currently accepting campaigns</p>
    </div>

    <div class="footer-col">
      <p class="footer-heading">Company</p>
      <ul>
        <li><a href="/about">About</a></li>
        <li><a href="/how-it-works">How It Works</a></li>
        <li><a href="/rider-program">Rider Program</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <p class="footer-heading">Resources</p>
      <ul>
        <li><a href="/events">Events</a></li>
        <li><a href="/gallery">Gallery</a></li>
        <li><a href="/faq">FAQ</a></li>
        <li><a href="/brand-guide">Brand Guide</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <p class="footer-heading">Get Started</p>
      <a href="/contact" class="btn btn-primary footer-cta">Start Your Campaign</a>
      <div class="footer-legal">
        <a href="/privacy-policy">Privacy Policy</a>
        <a href="/terms">Terms of Service</a>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <span>© {new Date().getFullYear()} BrandedBikers. All rights reserved.</span>
      <span class="footer-tagline">YOUR BRAND. THEIR BACKS. EVERYWHERE THAT MATTERS.</span>
    </div>
  </div>

  <div class="watermark-section">
    <div class="watermark-inner">
      <span class="watermark-text">Built by</span>
      <a
        href="https://egintegrations.com/badge"
        target="_blank"
        rel="noopener noreferrer"
        class="watermark-link egi-link"
        aria-label="Visit EGI Integrations website"
      >
        <img
          src="/watermarks/egi-logo.png"
          alt="EGI Integrations"
          width="140"
          height="46"
          class="watermark-logo"
        />
        <span class="watermark-overlay egi-overlay"></span>
      </a>
      <span class="watermark-text">, secured by</span>
      <a
        href="https://www.anchor-msp.com/secured-by-anchor"
        target="_blank"
        rel="noopener noreferrer"
        class="watermark-link anchor-link"
        aria-label="Visit Anchor MSP website"
      >
        <img
          src="/watermarks/anchor-logo.png"
          alt="Anchor MSP"
          width="120"
          height="40"
          class="watermark-logo"
        />
        <span class="watermark-overlay anchor-overlay"></span>
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-dark);
    border-top: 1px solid var(--border);
    margin-top: 4rem;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.5fr;
    gap: 3rem;
    padding: 3.5rem 2rem;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-size: 18px;
    letter-spacing: 2px;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .footer-brand img { width: 32px; height: 32px; object-fit: contain; mix-blend-mode: lighten; }

  .footer-desc {
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 0.75rem;
    max-width: 260px;
  }

  .footer-status {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: var(--text-muted);
  }

  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #5CB85C;
    flex-shrink: 0;
  }

  .footer-heading {
    font-family: var(--font-display);
    font-size: 11px;
    letter-spacing: 2px;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }

  .footer-col ul a {
    font-size: 13px;
    color: var(--text-muted);
    transition: color 0.15s;
  }

  .footer-col ul a:hover { color: var(--text); }

  .footer-cta { font-size: 13px; padding: 0.6rem 1.25rem; display: inline-block; }

  .footer-legal {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-top: 1rem;
  }

  .footer-legal a {
    font-size: 11.5px;
    color: var(--border-dim);
    transition: color 0.15s;
  }

  .footer-legal a:hover { color: var(--text-muted); }

  .footer-bottom {
    border-top: 0.5px solid var(--border);
    padding: 1.25rem 0;
  }

  .footer-bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 11px;
    color: var(--border);
    letter-spacing: 0.5px;
  }

  .footer-tagline { letter-spacing: 1px; font-family: var(--font-display); font-size: 12px; }

  @media (max-width: 768px) {
    .footer-inner { grid-template-columns: 1fr 1fr; gap: 2rem; }
    .footer-bottom-inner { flex-direction: column; gap: 0.5rem; text-align: center; }
  }

  @media (max-width: 480px) {
    .footer-inner { grid-template-columns: 1fr; }
  }

  .watermark-section {
    background: #ffffff;
    border-top: 1px solid #e5e5e5;
    padding: 1rem 0;
  }

  .watermark-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-size: 12px;
    color: #6b7280;
  }

  .watermark-text {
    opacity: 0.7;
  }

  .watermark-link {
    position: relative;
    display: inline-block;
    opacity: 0.6;
    transition: opacity 300ms ease;
  }

  .watermark-link:hover {
    opacity: 1;
  }

  .watermark-logo {
    height: auto;
    display: block;
    opacity: 0.6;
  }

  .egi-link .watermark-logo {
    max-width: 140px;
    margin-right: -8px;
  }

  .anchor-link .watermark-logo {
    max-width: 120px;
  }

  .watermark-overlay {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 300ms ease;
    -webkit-mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-size: contain;
    mask-repeat: no-repeat;
    mask-position: center;
    pointer-events: none;
  }

  .egi-overlay {
    background: #3ec3e0;
    -webkit-mask-image: url(/watermarks/egi-logo.png);
    mask-image: url(/watermarks/egi-logo.png);
  }

  .anchor-overlay {
    background: #69867E;
    -webkit-mask-image: url(/watermarks/anchor-logo.png);
    mask-image: url(/watermarks/anchor-logo.png);
  }

  .watermark-link:hover .watermark-overlay {
    opacity: 1;
  }
</style>
