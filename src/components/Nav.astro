---
const links = [
  { href: '/how-it-works', label: 'How It Works' },
  { href: '/rider-program', label: 'Rider Program' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
const current = Astro.url.pathname;
---

<nav class="nav">
  <div class="container nav-inner">
    <a href="/" class="nav-brand">
      <img src="https://www.brandedbikers.com/media/BBNoBG.png" alt="BrandedBikers" width="40" height="40" />
      <span>BRANDEDBIKERS</span>
    </a>

    <button class="nav-toggle" id="nav-toggle" aria-label="Toggle menu">
      <i class="ti ti-menu-2"></i>
    </button>

    <ul class="nav-links" id="nav-links">
      {links.map(l => (
        <li>
          <a href={l.href} class:list={['nav-link', { active: current.startsWith(l.href) }]}>
            {l.label}
          </a>
        </li>
      ))}
      <li>
        <a href="/contact" class="btn btn-primary nav-cta">Start Your Campaign</a>
      </li>
    </ul>
  </div>
</nav>

<script>
  const toggle = document.getElementById('nav-toggle');
  const links  = document.getElementById('nav-links');
  toggle?.addEventListener('click', () => links?.classList.toggle('open'));
</script>

<style>
  .nav {
    background: var(--bg-dark);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-size: 20px;
    letter-spacing: 2px;
    color: var(--text);
  }

  .nav-brand img { width: 36px; height: 36px; object-fit: contain; }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
  }

  .nav-link {
    font-family: var(--font-display);
    font-size: 13px;
    letter-spacing: 1.5px;
    color: var(--text-muted);
    padding: 0.4rem 0.75rem;
    transition: color 0.15s;
  }

  .nav-link:hover,
  .nav-link.active { color: var(--text); }

  .nav-cta { font-size: 13px; padding: 0.5rem 1.25rem; margin-left: 0.5rem; }

  .nav-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--text);
    font-size: 24px;
    cursor: pointer;
  }

  @media (max-width: 768px) {
    .nav-toggle { display: flex; }

    .nav-links {
      display: none;
      position: absolute;
      top: 64px;
      left: 0;
      right: 0;
      background: var(--bg-dark);
      border-bottom: 1px solid var(--border);
      flex-direction: column;
      align-items: flex-start;
      padding: 1rem 2rem 1.5rem;
      gap: 0.5rem;
    }

    .nav-links.open { display: flex; }
    .nav-cta { margin-left: 0; margin-top: 0.5rem; }
  }
</style>
